# BoldSign API (required)
BOLDSIGN_API_KEY=your_api_key_here

# API authentication (required in production when DEBUG=false)
API_KEY=your_api_key_here

# CORS - comma-separated origins (e.g. http://localhost:3000,https://app.example.com)
# Leave empty to deny all; set * for allow-all (dev only). When DEBUG=true, empty defaults to *
# CORS_ORIGINS=

# Optional: BoldSign API host (default: https://api.boldsign.com)
# BOLDSIGN_API_HOST=https://api.boldsign.com

# Optional: EU, CA, AU regions
# BOLDSIGN_API_HOST=https://eu-api.boldsign.com
# BOLDSIGN_API_HOST=https://ca-api.boldsign.com
# BOLDSIGN_API_HOST=https://au-api.boldsign.com

# Rate limiting (default: 100/minute)
# RATE_LIMIT=100/minute

# Optional
DEBUG=false
